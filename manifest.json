{
  "schema": 2,
  "permissions": ["tools.invoke", "storage.read", "storage.write"],
  "required_executas": [
    {
      "tool_id": "tool-dev-mini-notes-summarizer",
      "min_version": "1.0.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "tags": ["notes", "productivity", "llm-summary"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Mini Notes",
        "default": true,
        "min_size": { "w": 360, "h": 480 },
        "default_size": { "w": 520, "h": 640 },
        "max_size": { "w": 800, "h": 1000 },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "tools": ["required:tool-dev-mini-notes-summarizer"],
      "storage": ["get", "set"],
      "llm": ["complete"],
      "window": ["set_title"]
    },
    "csp_overrides": {},
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "seed_storage": {},
    "user_id": 1
  }
}
